<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"> <!-- Fondo negro para que los bordes del video no molesten -->

    <!-- ========================================== -->
    <!-- PANEL SUPERIOR: ESTADO Y COMANDOS          -->
    <!-- ========================================== -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#222222"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Aquí puedes meter tus botones y textos -->
        <TextView
            android:id="@+id/text_status_monitor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Estado: A la espera de señal de hardware DJI..."
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnTest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ejecutar Comando"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- ========================================== -->
    <!-- PANEL IZQUIERDO: VIDEO ORIGINAL (DJI)      -->
    <!-- ========================================== -->
    <FrameLayout
        android:id="@+id/originalVideoContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/processedVideoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topPanel">

        <!-- Aquí debes inyectar el SurfaceView o TextureView del DJI MSDK -->
        <!-- Se ajustará automáticamente al tamaño de este FrameLayout -->
        <SurfaceView
            android:id="@+id/surface_video_stream"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </FrameLayout>

    <!-- ========================================== -->
    <!-- PANEL DERECHO: VIDEO PROCESADO (OpenCV)    -->
    <!-- ========================================== -->
    <FrameLayout
        android:id="@+id/processedVideoContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/originalVideoContainer"
        app:layout_constraintTop_toBottomOf="@+id/topPanel">

        <!-- Aquí colocarás el ImageView donde pintarás los frames procesados -->
        <ImageView
            android:id="@+id/ivProcessedFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" /> <!-- fitCenter mantiene el aspect ratio de tus frames -->

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>